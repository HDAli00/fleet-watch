# ─────────────────────────────────────────────────────────────────────────────
# Solar IoT Platform — local development environment
# Copy this file to .env and fill in any values marked <REQUIRED>
# .env is git-ignored — never commit real secrets
# ─────────────────────────────────────────────────────────────────────────────

# Direct DB URL — bypasses AWS Secrets Manager (used by Docker Compose & tests)
DATABASE_URL=postgresql+asyncpg://solar:solar@localhost:5432/solar

# API settings
LOG_LEVEL=DEBUG
AWS_REGION=eu-west-1

# AWS credentials (needed for local scripts and CDK operations; not needed for
# Docker Compose which uses DATABASE_URL directly)
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# KNMI Open Data API key — only needed for knmi-poller and check_knmi.py script
# KNMI_API_KEY=<REQUIRED for KNMI scripts>

# CDK target account / region (overrides CDK_DEFAULT_ACCOUNT/REGION if set)
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=eu-west-1
